#!/usr/bin/env bash

set -u

VERSION="1.2.0"
SCRIPT_NAME="$(basename -- "${BASH_SOURCE[0]}")"
MATCH_PATH=""
TRAVERSED_FILES=0
TRAVERSED_DIRS=0
PERMISSION_DENIED_COUNT=0

is_sourced() {
    [[ "${BASH_SOURCE[0]}" != "$0" ]]
}

print_help() {
    cat <<EOF
findgo ${VERSION}

Search recursively from the current directory for the first file or directory
whose basename matches NAME exactly.

Usage:
  source ./${SCRIPT_NAME} <name>
  . ./${SCRIPT_NAME} <name>
  source ./${SCRIPT_NAME} --help
  source ./${SCRIPT_NAME} --version

Options:
  -h, --help       Show this help text.
      --version    Show the script version.

Notes:
  - Source the script to change your current shell directory.
  - Running the script directly can only print the matching directory.
EOF
}

print_version() {
    printf '%s %s\n' "findgo" "$VERSION"
}

shell_quote() {
    local quoted

    printf -v quoted '%q' "$1"
    printf '%s\n' "$quoted"
}

print_permission_summary() {
    if [[ "$PERMISSION_DENIED_COUNT" -gt 0 ]]; then
        printf 'Permission denied in %d directories.\n' "$PERMISSION_DENIED_COUNT"
    fi
}

count_find_errors() {
    local error_file line

    error_file="$1"
    PERMISSION_DENIED_COUNT=0

    while IFS= read -r line; do
        if [[ "$line" == *': Permission denied' ]]; then
            ((PERMISSION_DENIED_COUNT += 1))
            continue
        fi

        printf '%s\n' "$line" >&2
    done < "$error_file"
}

find_first_match() {
    local name path base error_file found_match temp_dir find_pipe find_pid

    name="$1"
    MATCH_PATH=""
    TRAVERSED_FILES=0
    TRAVERSED_DIRS=0
    found_match=1
    temp_dir="$(mktemp -d)" || return 1
    error_file="$temp_dir/find.stderr"
    find_pipe="$temp_dir/find.pipe"

    if ! mkfifo "$find_pipe"; then
        rm -rf -- "$temp_dir"
        return 1
    fi

    find . -mindepth 1 \( -type f -o -type d \) -print0 \
        >"$find_pipe" 2>"$error_file" &
    find_pid=$!

    while IFS= read -r -d '' path; do
        base="${path##*/}"

        if [[ -d "$path" ]]; then
            ((TRAVERSED_DIRS += 1))
        elif [[ -f "$path" ]]; then
            ((TRAVERSED_FILES += 1))
        else
            continue
        fi

        if [[ "$base" == "$name" ]] || [[ "$base" == *"$name"* ]]; then
            MATCH_PATH="$path"
            found_match=0
            break
        fi
    done < "$find_pipe"

    wait "$find_pid" 2>/dev/null || true

    count_find_errors "$error_file"
    rm -rf -- "$temp_dir"

    return "$found_match"
}

main() {
    local name target_dir script_ref quoted_name

    if [[ $# -eq 0 ]]; then
        print_help
        return 0
    fi

    case "$1" in
        -h|--help)
            print_help
            return 0
            ;;
        --version)
            print_version
            return 0
            ;;
    esac

    if [[ $# -ne 1 ]]; then
        print_help
        return 1
    fi

    name="$1"

    if [[ "$name" == */* ]]; then
        printf '%s\n' "Name must not contain '/': $name"
        return 1
    fi

    if ! find_first_match "$name"; then
        print_permission_summary
        printf '%s\n' "File or directory not found: $name"
        return 1
    fi

    if [[ -d "$MATCH_PATH" ]]; then
        target_dir="$MATCH_PATH"
    else
        target_dir="$(dirname -- "$MATCH_PATH")"
    fi

    printf 'Traversed %d directories and %d files before the match.\n' \
        "$TRAVERSED_DIRS" "$TRAVERSED_FILES"
    print_permission_summary

    if is_sourced; then
        cd -- "$target_dir" || return 1
        printf 'Changed directory to: %s\n' "$(pwd)"
        return 0
    fi

    script_ref="$(shell_quote "$0")"
    quoted_name="$(shell_quote "$name")"

    printf 'Found in: %s\n' "$target_dir"
    printf 'Run this script with: source %s %s\n' "$script_ref" "$quoted_name"
}

if is_sourced; then
    main "$@"
    return $?
fi

main "$@"
exit $?